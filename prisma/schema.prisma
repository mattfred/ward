generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  plan          String    @default("free") // free | premium
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  styleProfile  StyleProfile?
  lifeMap       LifeMap?
  styleSystem   StyleSystem?
  blueprint     WardrobeBlueprint?
  roadmap       RebuildRoadmap?
  events        AnalyticsEvent[]
  feedback      Feedback[]
  closetItems   ClosetItem[]
  outfits       Outfit[]
  tripWardrobes TripWardrobe[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model StyleProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  aestheticRefs   String
  preferredColors String
  avoidColors     String
  fitPreferences  String
  climate         String?
  budgetTier      String?
  trustedBrands   String
  values          String
  notes           String?
  genderPresentation String?
  ageRange        String?
  bodyNotes       String?
  heightBand      String?
  constraints     String   @default("[]")
  inspirationRefs String   @default("[]")
  antiRefs        String   @default("[]")
  formalityRange  String?
  closetHonesty   String?
  intakeMode      String   @default("guided")
  preferenceMemory String  @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LifeMap {
  id        String   @id @default(cuid())
  userId    String   @unique
  events    String
  primaryEventId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StyleSystem {
  id              String   @id @default(cuid())
  userId          String   @unique
  manifesto       String
  palette         String
  silhouettes     String
  fabrics         String
  alwaysRules     String
  neverRules      String
  signaturePieces String
  vibeReferences  String
  rawJson         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WardrobeBlueprint {
  id          String   @id @default(cuid())
  userId      String   @unique
  pieces      String
  summary     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RebuildRoadmap {
  id          String   @id @default(cuid())
  userId      String   @unique
  items       String
  weeklyFocus String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  props     String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  cohesive  Int
  comment   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClosetItem {
  id                String    @id @default(cuid())
  userId            String
  name              String
  category          String
  color             String?
  brand             String?
  notes             String?
  imageData         String?
  acquiredAt        DateTime?
  purchasePrice     Float?
  wearCount         Int       @default(0)
  lastWornAt        DateTime?
  condition         String    @default("good")
  season            String    @default("all")
  archived          Boolean   @default(false)
  blueprintPieceId  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, blueprintPieceId])
}

model Outfit {
  id          String    @id @default(cuid())
  userId      String
  name        String
  notes       String?
  itemIds     String    @default("[]")
  tags        String    @default("[]")
  occasion    String?
  imageData   String?
  wearCount   Int       @default(0)
  lastWornAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TripWardrobe {
  id                String    @id @default(cuid())
  userId            String
  name              String
  destination       String?
  startDate         DateTime?
  endDate           DateTime?
  itemIds           String    @default("[]")
  outfitIds         String    @default("[]")
  notes             String?
  packingChecklist  String    @default("[]")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
