DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
# Postgres example (docker compose):
# DATABASE_URL="postgresql://ward:ward@localhost:5432/ward?schema=public"

AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# Comma-separated admin emails for /metrics (required in production)
ADMIN_EMAILS=""

# Dev-only premium activation when Stripe unset (ignored in production)
ALLOW_DEV_PREMIUM_BYPASS=true

OPENAI_API_KEY=""

# Transactional email (password reset). Without these, emails log to console only.
RESEND_API_KEY=""
EMAIL_FROM="Ward <onboarding@resend.dev>"

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_MONTHLY=""
STRIPE_PRICE_YEARLY=""
